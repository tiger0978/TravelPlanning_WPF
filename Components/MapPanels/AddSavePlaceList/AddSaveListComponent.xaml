<UserControl
    x:Class="TravelPlanning.Components.MapPanels.AddSavePlaceList.AddSaveListComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:TravelPlanning.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Components.MapPanels.AddSavePlaceList"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:StarConverter x:Key="StarConverter" />
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="30,90,20,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        FontSize="20"
                        Text="😊" />

                    <!--  Display  -->
                    <TextBlock
                        x:Name="DisplayName"
                        Cursor="IBeam"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding SaveListName, Mode=TwoWay}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.InputBindings>
                            <MouseBinding Command="{Binding BeginEditNameCommand}" MouseAction="LeftClick" />
                        </TextBlock.InputBindings>
                    </TextBlock>

                    <!--  Edit  -->
                    <TextBox
                        x:Name="EditName"
                        MinWidth="120"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding SaveListName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>

                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding EndEditNameCommand}" />
                            <KeyBinding Key="Escape" Command="{Binding CancelEditNameCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>
            </Grid>


            <!--  Subtitle  -->
            <TextBlock
                Margin="0,6,0,12"
                Foreground="Gray"
                Text="{Binding SaveListCount, StringFormat={}{0} 個地點}" />

            <!--  Search  -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border
                    Height="30"
                    Margin="0,10,20,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="White"
                    BorderBrush="#DEE2E6"
                    BorderThickness="1"
                    CornerRadius="24">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="10"
                            Opacity="0.2"
                            ShadowDepth="2" />
                    </Border.Effect>
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid x:Name="PlaceContainer" Grid.Column="0" />
                        <ui:SymbolIcon
                            Grid.Column="1"
                            Cursor="Hand"
                            Foreground="#70757A"
                            Symbol="Search24" />
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>

        <!--  List  -->
        <ListView
            Grid.Row="1"
            Margin="20,5,20,0"
            BorderThickness="0"
            ItemsSource="{Binding SaveLists}"
            ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Width="390"
                        Padding="8"
                        Background="White"
                        CornerRadius="10"
                        Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Image  -->
                            <Border
                                Width="75"
                                Height="75"
                                ClipToBounds="True"
                                CornerRadius="6">
                                <Image Source="{Binding Cover}" Stretch="Fill" />
                            </Border>

                            <!--  Info  -->
                            <StackPanel Grid.Column="1" Margin="10,0">
                                <!--  Name  -->
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Name}" />

                                <!--  Rating  -->
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding Stars}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="1"
                                                    FontSize="14"
                                                    Foreground="#F9AB00"
                                                    Text="{Binding Converter={StaticResource StarConverter}}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock
                                        Margin="6,3,0,0"
                                        FontSize="12"
                                        Foreground="Gray"
                                        Text="{Binding Rate}" />
                                </StackPanel>

                                <!--  Type  -->
                                <TextBlock
                                    FontSize="12"
                                    Foreground="Gray"
                                    Text="{Binding Type}" />
                            </StackPanel>

                            <!--  Right buttons  -->
                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Top"
                                Orientation="Horizontal">
                                <Button
                                    HorizontalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                    <ui:SymbolIcon
                                        FontSize="16"
                                        Foreground="#EA4335"
                                        Symbol="Delete24" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
