<UserControl x:Class="TravelPlanning.Components.MapPanels.MapPanelComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">

    <UserControl.Resources>
        <Storyboard x:Key="ExpandPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="LeftColumn"
                             Storyboard.TargetProperty="Width"
                             To="400" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="CollapsePanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="LeftColumn"
                             Storyboard.TargetProperty="Width"
                             To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,4,4,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="AntiqueWhite"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65"/>
            <ColumnDefinition x:Name="LeftColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#202124" Panel.ZIndex="100">
            <StackPanel Margin="0,15,0,0">
                <ItemsControl ItemsSource="{Binding PageItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemContainer" 
                                    Margin="4,2,4,8" 
                                    Padding="0,10" 
                                    CornerRadius="8" 
                                    Background="Transparent"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding DataContext.ChangePageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding TargetPageType}"/>
                                </Border.InputBindings>

                                <StackPanel>
                                    <ui:SymbolIcon x:Name="Icon" 
                                                   Symbol="{Binding IconKey}" 
                                                   FontSize="22" 
                                                   Foreground="#BDC1C6" 
                                                   HorizontalAlignment="Center"/>

                                    <TextBlock x:Name="Txt" 
                                               Text="{Binding Name}" 
                                               FontSize="11" 
                                               Margin="0,6,0,0" 
                                               Foreground="#BDC1C6" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemContainer" Property="Background" Value="#3C4043"/>
                                    <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                    <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="White" x:Name="PanelContainer">
            <Grid.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="0" Direction="0"/>
            </Grid.Effect>

            <ContentControl Content="{Binding CurrentComponent}" />

            <Border VerticalAlignment="Top" Margin="15" Height="48" 
                    Background="White" CornerRadius="8" BorderBrush="#DEE2E6" BorderThickness="1"
                    Panel.ZIndex="50">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" x:Name="PlaceContainer"></Grid>
                    <!--<TextBlock Text="搜尋 Google 地圖" VerticalAlignment="Center" Foreground="#70757A"/>-->
                    <ui:SymbolIcon Symbol="Search24" Grid.Column="1" Foreground="#70757A"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Panel.ZIndex="999">
            <Button Style="{StaticResource ToggleButtonStyle}" 
                    Margin="0,0,-24,0" 
                    Click="ToggleBtn_Click">
                <ui:SymbolIcon x:Name="ToggleIcon" Symbol="ChevronRight24" FontSize="14" Foreground="#70757A"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>