<UserControl
    x:Class="TravelPlanning.Components.MapPanels.MapPanelComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ac="clr-namespace:TravelPlanning.Components.AutoComplete"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="600"
    d:DesignWidth="500"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Storyboard x:Key="ExpandPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="LeftColumn"
                Storyboard.TargetProperty="Width"
                To="400"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="CollapsePanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="LeftColumn"
                Storyboard.TargetProperty="Width"
                To="0"
                Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0,4,4,0">

                            <!--  🔥 把 Icon 放進來  -->
                            <ui:SymbolIcon
                                x:Name="ToggleIcon"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="#70757A"
                                Symbol="ChevronRight12" />
                        </Border>

                        <!--  🔥 Trigger 在這  -->
                        <ControlTemplate.Triggers>

                            <!--  Checked → 左箭頭  -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleIcon" Property="Symbol" Value="ChevronRight12" />
                            </Trigger>

                            <!--  Unchecked → 右箭頭  -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="ToggleIcon" Property="Symbol" Value="ChevronLeft12" />
                            </Trigger>

                            <!--  Hover  -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="AntiqueWhite" />
                            </Trigger>

                            <!--  Pressed  -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#D2E3FC" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65" />
            <ColumnDefinition x:Name="LeftColumn" Width="440" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Column="0"
            Panel.ZIndex="100"
            Background="#202124">
            <StackPanel Margin="0,15,0,0">
                <ItemsControl ItemsSource="{Binding PageItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                x:Name="ItemContainer"
                                Margin="4,2,4,8"
                                Padding="0,10"
                                Background="Transparent"
                                CornerRadius="8"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding
                                        Command="{Binding DataContext.ChangePageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding TargetPageType}"
                                        MouseAction="LeftClick" />
                                </Border.InputBindings>

                                <StackPanel>
                                    <ui:SymbolIcon
                                        x:Name="Icon"
                                        HorizontalAlignment="Center"
                                        FontSize="22"
                                        Foreground="#BDC1C6"
                                        Symbol="{Binding IconKey}" />

                                    <TextBlock
                                        x:Name="Txt"
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#BDC1C6"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </Border>

                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemContainer" Property="Background" Value="#3C4043" />
                                    <Setter TargetName="Icon" Property="Foreground" Value="White" />
                                    <Setter TargetName="Txt" Property="Foreground" Value="White" />
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>


        <Border
            Grid.Column="1"
            Height="48"
            Margin="20,25,20,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Panel.ZIndex="999"
            Background="White"
            BorderBrush="#DEE2E6"
            BorderThickness="1"
            CornerRadius="24">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.2"
                    ShadowDepth="2" />
            </Border.Effect>
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--<Grid x:Name="PlaceContainer" Grid.Column="0" />-->
                <ac:AutoCompleteComponent Grid.Column="0" SelectedItemCommand="{Binding SelectItemCommand}" />
                <Button
                    Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ClearCommand}"
                    Cursor="Hand">
                    <ui:SymbolIcon Foreground="#70757A" Symbol="Dismiss24" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="Transparent">
            <ContentControl Name="ContentContainer" />
        </Grid>
        <Grid
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Panel.ZIndex="999">
            <ToggleButton
                x:Name="ToggleButton"
                Margin="0,0,-24,0"
                Checked="ToggleButton_Checked"
                Cursor="Hand"
                Style="{StaticResource ToggleButtonStyle}"
                Unchecked="ToggleButton_Unchecked"
                Visibility="{Binding ToggleButtonVisibility}">

                <ui:SymbolIcon
                    x:Name="ToggleIcon"
                    FontSize="14"
                    Foreground="#70757A"
                    Symbol="ChevronLeft24" />
            </ToggleButton>
        </Grid>
    </Grid>
</UserControl>