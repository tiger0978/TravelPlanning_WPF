<UserControl
    x:Class="TravelPlanning.Components.MapPanels.PlanRoutePanel.PlanRouteComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Components.MapPanels.PlanRoutePanel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="465"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="MapActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#F2F7F9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Padding="6"
                            Background="{TemplateBinding Background}"
                            CornerRadius="20">
                            <ui:SymbolIcon
                                x:Name="Icon"
                                FontSize="22"
                                Foreground="#5F6368"
                                Symbol="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E6F2F7" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#1967D2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D6EBF5" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E8F0FE" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#1967D2" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Margin="24,90,30,0">
            <StackPanel>
                <ItemsControl Margin="30,0,0,15" ItemsSource="{Binding Traffics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Command="{Binding DataContext.SelectModeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource MapActionButtonStyle}"
                                Tag="{Binding IconKey}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Ellipse
                            Width="6"
                            Height="6"
                            Fill="#4285F4" />
                        <Rectangle
                            Width="1"
                            Height="28"
                            Margin="0,4"
                            Fill="#DADCE0" />
                        <ui:SymbolIcon
                            FontSize="16"
                            Foreground="#EA4335"
                            Symbol="Location24" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Border
                            Height="38"
                            Margin="0,0,0,10"
                            Background="#F1F3F4"
                            CornerRadius="6">
                            <Grid Margin="10,0">
                                <Grid x:Name="StartSearchContainer" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="#70757A"
                                    IsHitTestVisible="False"
                                    Text="選擇起點..."
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <Border
                            Height="38"
                            Background="#F1F3F4"
                            CornerRadius="6">
                            <Grid Margin="10,0">
                                <Grid x:Name="EndSearchContainer" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="#70757A"
                                    IsHitTestVisible="False"
                                    Text="選擇終點..."
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right">
                <ui:Button
                    Height="40"
                    Margin="0,25,0,0"
                    Background="#E6E6F2"
                    Command="{Binding SearchRouteCommand}"
                    Content="搜尋路徑"
                    CornerRadius="20"
                    Cursor="Hand"
                    FontWeight="Medium"
                    Foreground="Black"
                    MouseOverBackground="#9999CC" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Separator
                Height="1"
                Margin="0,0,0,5"
                Background="#F1F3F4" />
            <ItemsControl ItemsSource="{Binding Routes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Border
                                x:Name="MainCard"
                                Padding="20,15"
                                Background="Transparent"
                                BorderBrush="#F1F3F4"
                                BorderThickness="0,0,0,1"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding Command="{Binding ToggleExpandCommand}" MouseAction="LeftClick" />
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ui:SymbolIcon
                                        Grid.Column="0"
                                        Margin="0,5"
                                        VerticalAlignment="Top"
                                        Foreground="#5F6368"
                                        Symbol="{Binding IconKey}" />
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="#202124"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Margin="0,10,0,0"
                                            FontSize="12"
                                            FontWeight="Medium"
                                            Foreground="#1A73E8"
                                            Text="詳細資料" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="#188038"
                                            Text="{Binding Duration}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="12"
                                            Foreground="#70757A"
                                            Text="{Binding Distance}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border
                                x:Name="DetailPanel"
                                Background="#FBFCFD"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="30,10,20,20">
                                    <TextBlock
                                        Margin="30,0,0,10"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="目前位置" />

                                    <ItemsControl ItemsSource="{Binding RouteDetails}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                        <ui:SymbolIcon
                                                            FontSize="14"
                                                            Foreground="#BDC1C6"
                                                            Symbol="{Binding IconKey}" />
                                                        <Rectangle
                                                            Width="1"
                                                            Height="25"
                                                            Margin="0,5"
                                                            Fill="#DADCE0" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="10,0">
                                                        <TextBlock
                                                            FontSize="13"
                                                            Foreground="#3C4043"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            Margin="0,2"
                                                            FontSize="11"
                                                            Foreground="#70757A"
                                                            Text="{Binding Duration}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon
                                            Margin="5,0,15,0"
                                            Foreground="#EA4335"
                                            Symbol="Location24" />
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Text="目的地" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <DataTemplate.Triggers>
                            <Trigger SourceName="MainCard" Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainCard" Property="Background" Value="#F8F9FA" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
