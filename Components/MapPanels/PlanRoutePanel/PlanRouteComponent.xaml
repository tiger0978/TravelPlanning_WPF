<UserControl x:Class="TravelPlanning.Components.MapPanels.PlanRoutePanel.PlanRouteComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TravelPlanning.Components.MapPanels.PlanRoutePanel"
             mc:Ignorable="d" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DesignHeight="450" d:DesignWidth="465">
    
    <UserControl.Resources>
        <Style x:Key="MapActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F2F7F9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="20"
                        Padding="6">
                            <ui:SymbolIcon x:Name="Icon" 
                                   Symbol="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                   FontSize="22" 
                                   Foreground="#5F6368"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E6F2F7"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="#1967D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D6EBF5"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E8F0FE"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="#1967D2"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Margin="24,20,30,0">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Traffics}" Margin="30,0,0,15">
                    <ItemsControl.ItemsPanel >
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectModeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Tag="{Binding IconKey}"
                             Style="{StaticResource MapActionButtonStyle}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="#4285F4"/>
                        <Rectangle Width="1" Height="28" Fill="#DADCE0" Margin="0,4"/>
                        <ui:SymbolIcon Symbol="Location24" Foreground="#EA4335" FontSize="16"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Border Height="38" Background="#F1F3F4" CornerRadius="6" Margin="0,0,0,10">
                            <Grid Margin="10,0">
                                <Grid x:Name="StartSearchContainer"/>
                                <TextBlock Text="選擇起點..." VerticalAlignment="Center" Foreground="#70757A" 
                            IsHitTestVisible="False" Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <Border Height="38" Background="#F1F3F4" CornerRadius="6">
                            <Grid Margin="10,0">
                                <Grid x:Name="EndSearchContainer"/>
                                <TextBlock Text="選擇終點..." VerticalAlignment="Center" Foreground="#70757A" 
                            IsHitTestVisible="False" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right">
                <ui:Button
                      Content="搜尋路徑"
                      Background="#E6E6F2"
                      Height="40" 
                      CornerRadius="20"
                      FontWeight="Medium"
                      Margin="0,25,0,0"
                      Cursor="Hand"
                      Foreground="Black"
                      MouseOverBackground="#9999CC"
                      Command="{Binding SearchRouteCommand}">
                </ui:Button>
            </StackPanel>
        </StackPanel>

            <StackPanel Grid.Row="1">
                <Separator Background="#F1F3F4" Height="1" Margin="0,0,0,5"/>
                <ItemsControl ItemsSource="{Binding Routes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border x:Name="MainCard" Background="Transparent" BorderBrush="#F1F3F4" BorderThickness="0,0,0,1" Cursor="Hand"  Padding="20,15">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandCommand}"/>
                                    </Border.InputBindings>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Symbol="{Binding IconKey}" Grid.Column="0" VerticalAlignment="Top" Margin="0,5" Foreground="#5F6368"/>
                                        <StackPanel Grid.Column="1" Margin="10,0">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#202124"/>
                                            <TextBlock Text="詳細資料" FontSize="12" Foreground="#1A73E8" Margin="0,10,0,0" FontWeight="Medium"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Duration}" FontSize="16" FontWeight="Bold" Foreground="#188038" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Distance}" FontSize="12" Foreground="#70757A" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border x:Name="DetailPanel" Background="#FBFCFD" 
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Margin="30,10,20,20">
                                        <TextBlock Text="目前位置" FontSize="14" FontWeight="Bold" Margin="30,0,0,10"/>

                                        <ItemsControl ItemsSource="{Binding RouteDetails}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,15">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                            <ui:SymbolIcon Symbol="{Binding IconKey}" FontSize="14" Foreground="#BDC1C6"/>
                                                            <Rectangle Width="1" Height="25" Fill="#DADCE0" Margin="0,5"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Margin="10,0">
                                                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#3C4043"/>
                                                            <TextBlock Text="{Binding Duration}" FontSize="11" Foreground="#70757A" Margin="0,2"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Location24" Foreground="#EA4335" Margin="5,0,15,0"/>
                                            <TextBlock Text="目的地" FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True" SourceName="MainCard">
                                    <Setter TargetName="MainCard" Property="Background" Value="#F8F9FA"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
    </Grid>
</UserControl>
