<UserControl
    x:Class="TravelPlanning.Components.PopUps.PlaceDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TravelPlanning.Components.PopUps"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>

        <!--  地圖  -->

        <!--  Popup  -->
        <Popup
            AllowsTransparency="True"
            IsOpen="{Binding IsPopupOpen}"
            Placement="Mouse"
            StaysOpen="False">

            <Border
                Width="260"
                Padding="14"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="12">

                <StackPanel>

                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Text="{Binding SelectedPlace.Name}" />

                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="Gray"
                        Text="{Binding SelectedPlace.Type}" />

                    <TextBlock Margin="0,6,0,0" Text="{Binding SelectedPlace.Rating, StringFormat=評分 {0}}" />

                    <Button
                        Margin="0,10,0,0"
                        HorizontalAlignment="Right"
                        Content="查看詳情" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>

</UserControl>
