<Page x:Class="TravelPlanning.Views.Pages.FavoriteTravel.FavoriteTravel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TravelPlanning.Views.Pages.FavoriteTravel"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FavoriteTravel">

    <Grid>
        
        <Button Content="HELLO"></Button>
        <Border 
            Panel.ZIndex="20"
            Background="White"
            CornerRadius="8"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="20"
            Height="35">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <Grid Name="PlaceContainer" Width="400">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="325"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Symbol="Search12" Grid.Column="1"/>
                <ui:SymbolIcon Symbol="Dismiss12" Grid.Column="2"/>
            </Grid>
        </Border>

        <!-- 右側懸浮的導航列表 -->
        <Border 
            Panel.ZIndex="10"
            Background="White"
            CornerRadius="8"
            Padding="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Margin="20"
            Width="400">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>
                <TextBlock Text="Route / Steps here..." />
        </Border>

    </Grid>
</Page>
