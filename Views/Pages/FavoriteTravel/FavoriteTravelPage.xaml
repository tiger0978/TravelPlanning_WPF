<Page 
    x:Class="TravelPlanning.Views.Pages.FavoriteTravel.FavoriteTravelPage" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:TravelPlanning.Views.Pages.FavoriteTravel" 
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" 
    mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800" Title="FavoriteTravel">

    <Page.Resources>
        <Style x:Key="NoHoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Style.Triggers>
                <!-- 滑鼠經過也維持相同外觀 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#CCC"/>
                </Trigger>

                <!-- 按下也維持相同外觀（或你想要的按下色） -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="White"/>
                </Trigger>

                <!-- disabled 狀態可保持淡出 -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Name="MapContainer" Grid.Column="0" Panel.ZIndex="1"></Grid>
        
        <Grid Grid.Column="0" Panel.ZIndex="2" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid Name="PlaceContainer"></Grid>
        </Grid>
    </Grid>
</Page>